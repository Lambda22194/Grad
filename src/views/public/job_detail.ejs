<%- include("../partials/header", { title: job.title }) %>
<h1 class="mt-3"><%= job.title %></h1>
<p class="text-muted mb-1"><strong><%= job.company_name %></strong> — <%= job.location %> — <span class="badge text-bg-secondary"><%= job.type %></span></p>
<p><small class="text-muted">Tags: <%= job.tags || '-' %></small></p>
<hr/>
<p style="white-space: pre-wrap"><%= job.description %></p>

<% if (currentUser && currentUser.role === 'student') { %>
  <form method="post" action="/student/apply/<%= job.id %>">
    <button class="btn btn-success">Apply</button>
  </form>
<% } else { %>
  <p class="text-muted">Login as a student to apply.</p>
<% } %>

<%- include("../partials/footer") %>

<%- include("../partials/header", { title: "Jobs" }) %>
<h1 class="mt-3">Jobs & Internships</h1>

<form class="row g-2 mt-2" method="get" action="/jobs">
  <div class="col-md-4">
    <input class="form-control" name="q" placeholder="Search title, tags, description" value="<%= filters.q %>"/>
  </div>
  <div class="col-md-3">
    <select class="form-select" name="type">
      <option value="">All types</option>
      <option value="job" <%= filters.type==='job' ? 'selected' : '' %>>Job</option>
      <option value="internship" <%= filters.type==='internship' ? 'selected' : '' %>>Internship</option>
    </select>
  </div>
  <div class="col-md-3">
    <input class="form-control" name="location" placeholder="Location" value="<%= filters.location %>"/>
  </div>
  <div class="col-md-2">
    <button class="btn btn-primary w-100">Filter</button>
  </div>
</form>

<div class="list-group mt-3">
  <% jobs.forEach(j => { %>
    <a class="list-group-item list-group-item-action" href="/jobs/<%= j.id %>">
      <div class="d-flex justify-content-between">
        <strong><%= j.title %></strong>
        <span class="badge text-bg-secondary"><%= j.type %></span>
      </div>
      <div class="text-muted"><%= j.company_name %> — <%= j.location %></div>
      <small class="text-muted">Tags: <%= j.tags || '-' %></small>
    </a>
  <% }) %>
</div>
<%- include("../partials/footer") %>

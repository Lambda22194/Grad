<%- include("../partials/header", { title: "Register Employer" }) %>
<h1 class="mt-3">Register as Employer</h1>
<p class="text-muted">Employer accounts require admin verification before posting jobs.</p>
<form method="post" action="/auth/register/employer" class="mt-3" style="max-width: 600px;">
  <div class="row g-2">
    <div class="col-md-6 mb-3">
      <label class="form-label">Company name</label>
      <input class="form-control" name="company_name" required/>
    </div>
    <div class="col-md-6 mb-3">
      <label class="form-label">Contact name</label>
      <input class="form-control" name="contact_name" required/>
    </div>
  </div>
  <div class="row g-2">
    <div class="col-md-6 mb-3">
      <label class="form-label">Email</label>
      <input class="form-control" type="email" name="email" required/>
    </div>
    <div class="col-md-6 mb-3">
      <label class="form-label">Website (optional)</label>
      <input class="form-control" name="website"/>
    </div>
  </div>
  <div class="mb-3">
    <label class="form-label">Password</label>
    <input class="form-control" type="password" name="password" minlength="6" required/>
  </div>
  <button class="btn btn-success">Create employer account</button>
</form>
<%- include("../partials/footer") %>

<%- include("../partials/header", { title: "Register Student" }) %>
<h1 class="mt-3">Register as Student</h1>
<form method="post" action="/auth/register/student" class="mt-3" style="max-width: 520px;">
  <div class="mb-3">
    <label class="form-label">Full name</label>
    <input class="form-control" name="full_name" required/>
  </div>
  <div class="mb-3">
    <label class="form-label">Email</label>
    <input class="form-control" type="email" name="email" required/>
  </div>
  <div class="mb-3">
    <label class="form-label">Password</label>
    <input class="form-control" type="password" name="password" minlength="6" required/>
  </div>
  <button class="btn btn-success">Create account</button>
</form>
<%- include("../partials/footer") %>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= title || "Recruitment Platform" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/">Recruitment Platform</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/jobs">Jobs & Internships</a></li>
      </ul>
      <ul class="navbar-nav">
        <% if (!currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Register</a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/auth/register/student">Student</a></li>
              <li><a class="dropdown-item" href="/auth/register/employer">Employer</a></li>
            </ul>
          </li>
        <% } else { %>
          <% if (currentUser.role === "student") { %>
            <li class="nav-item"><a class="nav-link" href="/student/dashboard">Student Dashboard</a></li>
          <% } %>
          <% if (currentUser.role === "employer") { %>
            <li class="nav-item"><a class="nav-link" href="/employer/dashboard">Employer Dashboard</a></li>
          <% } %>
          <% if (currentUser.role === "admin") { %>
            <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Admin Dashboard</a></li>
          <% } %>
          <li class="nav-item">
            <form method="post" action="/auth/logout" class="d-inline">
              <button class="btn btn-sm btn-outline-light ms-2">Logout</button>
            </form>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<div class="container mt-3">
  <% if (messages.success && messages.success.length) { %>
    <div class="alert alert-success"><%= messages.success[0] %></div>
  <% } %>
  <% if (messages.error && messages.error.length) { %>
    <div class="alert alert-danger"><%= messages.error[0] %></div>
  <% } %>

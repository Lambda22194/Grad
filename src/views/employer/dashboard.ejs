<%- include("../partials/header", { title: "Employer Dashboard" }) %>
<h1 class="mt-3">Employer Dashboard</h1>

<div class="alert alert-<%= profile.is_verified ? 'success' : 'warning' %> mt-3">
  Verification status: <strong><%= profile.is_verified ? 'Verified' : 'Pending' %></strong>
  <% if (!profile.is_verified) { %><div class="small">You can edit profile, but job posting is disabled until verified.</div><% } %>
</div>

<div class="d-flex gap-2">
  <a class="btn btn-outline-primary" href="/employer/profile">Company Profile</a>
  <a class="btn btn-primary <%= profile.is_verified ? '' : 'disabled' %>" href="/employer/jobs/new">Post Job/Internship</a>
</div>

<h4 class="mt-4">My Postings</h4>
<table class="table table-striped mt-2">
  <thead>
    <tr>
      <th>Title</th>
      <th>Type</th>
      <th>Location</th>
      <th>Status</th>
      <th>Applications</th>
    </tr>
  </thead>
  <tbody>
    <% jobs.forEach(j => { %>
      <tr>
        <td><%= j.title %></td>
        <td><%= j.type %></td>
        <td><%= j.location %></td>
        <td><%= j.status %></td>
        <td><a href="/employer/jobs/<%= j.id %>/applications">View</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include("../partials/footer") %>

<%- include("../partials/header", { title: "Student Profile" }) %>
<h1 class="mt-3">Manage Profile</h1>
<form method="post" action="/student/profile?_method=PUT" class="mt-3" style="max-width: 700px;">
  <div class="mb-3">
    <label class="form-label">Full name</label>
    <input class="form-control" name="full_name" value="<%= profile.full_name || '' %>"/>
  </div>
  <div class="row g-2">
    <div class="col-md-6 mb-3">
      <label class="form-label">University</label>
      <input class="form-control" name="university" value="<%= profile.university || '' %>"/>
    </div>
    <div class="col-md-6 mb-3">
      <label class="form-label">Major</label>
      <input class="form-control" name="major" value="<%= profile.major || '' %>"/>
    </div>
  </div>
  <div class="mb-3">
    <label class="form-label">Skills/Interests (comma-separated)</label>
    <input class="form-control" name="skills" value="<%= profile.skills || '' %>" placeholder="e.g., JavaScript, React, SQL"/>
  </div>
  <button class="btn btn-primary">Save</button>
</form>

<hr class="my-4"/>

<h4>Upload CV</h4>
<form method="post" action="/student/profile/upload-cv" enctype="multipart/form-data" style="max-width: 700px;">
  <div class="mb-3">
    <input class="form-control" type="file" name="cv_file" required/>
  </div>
  <button class="btn btn-outline-success">Upload</button>
  <% if (profile.cv_file_path) { %>
    <p class="mt-2">Current CV: <a href="<%= profile.cv_file_path %>" target="_blank">View</a></p>
  <% } %>
</form>

<%- include("../partials/footer") %>

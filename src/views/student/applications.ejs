<%- include("../partials/header", { title: "My Applications" }) %>
<h1 class="mt-3">My Applications</h1>
<table class="table table-striped mt-3">
  <thead>
    <tr>
      <th>Opportunity</th>
      <th>Company</th>
      <th>Type</th>
      <th>Status</th>
      <th>Applied</th>
    </tr>
  </thead>
  <tbody>
    <% apps.forEach(a => { %>
      <tr>
        <td><%= a.title %></td>
        <td><%= a.company_name %></td>
        <td><%= a.type %></td>
        <td><span class="badge text-bg-info text-dark"><%= a.status %></span></td>
        <td><%= new Date(a.created_at).toLocaleDateString() %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include("../partials/footer") %>
